{
  "name": "@subito/api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.3",
    "@subito/db": "workspace:*",
    "bullmq": "^5.34.8",
    "dotenv": "^17.4.1",
    "firebase-admin": "^13.4.0",
    "hono": "^4.7.5",
    "ioredis": "^5.4.2",
    "jose": "^6.0.11",
    "nanoid": "^5.1.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@subito/eslint-config": "workspace:*",
    "@subito/typescript-config": "workspace:*",
    "@types/node": "^22.15.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
