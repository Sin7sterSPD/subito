{
  "name": "@subito/worker",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@subito/db": "workspace:*",
    "bullmq": "^5.34.8",
    "dotenv": "^17.4.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@subito/eslint-config": "workspace:*",
    "@subito/typescript-config": "workspace:*",
    "@types/node": "^22.15.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
