# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subito

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=subito-api
JWT_AUDIENCE=subito-app
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Firebase Admin SDK
# Option 1: Service account JSON (for local development)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}
# Option 2: Use application default credentials (for production)

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Juspay Configuration
JUSPAY_API_KEY=your-juspay-api-key
JUSPAY_MERCHANT_ID=your-merchant-id

# CleverTap Configuration
CLEVERTAP_ACCOUNT_ID=your-clevertap-account-id
CLEVERTAP_PASSCODE=your-clevertap-passcode

# Storage
STORAGE_BASE_URL=https://storage.subito.in

# Server Configuration
PORT=3000
NODE_ENV=development
